// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(cuid())
  createdAt              DateTime  @default(now())
  email                  String    @unique
  alias                  String?
  aliasSetByUser         Boolean   @default(false)
  referralCode           String?
  isGuest                Boolean   @default(false)
  tier                   Int       @default(1)
  freeCreditsBalance      Int       @default(0)
  paidCreditsBalance      Int       @default(0)
  lastDailyCreditsDayKey  String?

  attempts   Attempt[]
  purchases  ItemPurchase[]
  winners    Winner[]
}

model Item {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  title                 String
  tier                  Int       @default(1)
  prizeType             String
  prizeValueZAR         Int       @default(0)
  imageUrl              String?
  shortDesc             String?
  productUrl            String?
  state                 String    @default("OPEN") // OPEN | ACTIVATED | CLOSED | PUBLISHED
  activationGoalEntries Int       @default(3)
  countdownMinutes      Int       @default(5)
  opensAt               DateTime?
  closesAt              DateTime?
  subscriberOnly        Boolean   @default(false)
  gameKey               String?

  attempts  Attempt[]
  winners   Winner[]
  purchases ItemPurchase[]
}

model Attempt {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  userId           String
  itemId           String
  dayKey           String

  // Payment attribution (for exact "buy the difference" math)
  costCredits      Int       @default(0) // total credits charged for this attempt
  freeUsed         Int       @default(0) // portion taken from free balance
  paidUsed         Int       @default(0) // portion taken from paid balance
  isPaid           Boolean   @default(false) // true if any paid credits were used

  scoreMs          Int
  flags            String?
  clientSentAt     DateTime?
  serverReceivedAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
  item Item @relation(fields: [itemId], references: [id])

  @@index([itemId, dayKey])
  @@index([userId, dayKey])
  @@index([itemId, dayKey, userId])
}

model Winner {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  itemId    String
  dayKey    String
  userId    String
  rank      Int
  scoreMs   Int
  alias     String?

  item Item @relation(fields: [itemId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([itemId, dayKey])
  @@index([userId, dayKey])
  @@unique([itemId, dayKey, userId])
}

model ItemPurchase {
  id             String   @id @default(cuid())
  createdAt       DateTime @default(now())
  itemId          String
  userId          String
  dayKey          String

  priceCredits    Int
  spentCredits    Int
  discountPct     Int
  discountCredits Int
  payCredits      Int
  tierKey         String

  item Item @relation(fields: [itemId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([itemId, dayKey])
  @@index([userId, dayKey])
  @@unique([itemId, dayKey, userId])
}