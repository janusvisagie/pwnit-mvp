generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                @id @default(cuid())
  createdAt              DateTime              @default(now())
  email                  String                @unique
  passwordHash           String?
  passwordSetAt          DateTime?
  alias                  String?
  referralCode           String?
  isGuest                Boolean               @default(false)
  aliasSetByUser         Boolean               @default(false)
  tier                   Int                   @default(1)
  freeCreditsBalance     Int                   @default(0)
  paidCreditsBalance     Int                   @default(0)
  lastDailyCreditsDayKey String?
  emailVerifiedAt        DateTime?
  attempts               Attempt[]
  purchases              ItemPurchase[]
  winners                Winner[]
  ledgers                CreditLedger[]
  dailyFreeGrants        DailyFreeBucketGrant[]
  referralsMade          Referral[]            @relation("ReferralReferrer")
  referralsReceived      Referral[]            @relation("ReferralReferred")
  surveyResponses        SurveyResponse[]
}

model Item {
  id                    String         @id @default(cuid())
  createdAt             DateTime       @default(now())
  title                 String
  tier                  Int            @default(1)
  prizeType             String
  prizeValueZAR         Int            @default(0)
  landedCostZAR         Int            @default(0)
  allowedSubsidyCredits Int            @default(0)
  playCostCredits       Int            @default(5)
  fundingWindowHours    Int            @default(48)
  purchaseGraceHours    Int            @default(24)
  sortOrder             Int            @default(0)
  isHero                Boolean        @default(false)
  imageUrl              String?
  shortDesc             String?
  productUrl            String?
  state                 String         @default("OPEN")
  activationGoalEntries Int            @default(3)
  countdownMinutes      Int            @default(120)
  opensAt               DateTime?
  closesAt              DateTime?
  subscriberOnly        Boolean        @default(false)
  gameKey               String?
  attempts              Attempt[]
  winners               Winner[]
  purchases             ItemPurchase[]
  rounds                ItemRound[]
  ledgers               CreditLedger[]
}

model ItemRound {
  id                      String         @id @default(cuid())
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  itemId                  String
  sequence                Int            @default(1)
  state                   String         @default("BUILDING")
  fundingStartsAt         DateTime       @default(now())
  fundingEndsAt           DateTime
  activatedAt             DateTime?
  closesAt                DateTime?
  purchaseGraceEndsAt     DateTime?
  activationTargetCredits Int            @default(0)
  paidCreditsCollected    Int            @default(0)
  freeCreditsCollected    Int            @default(0)
  attemptCount            Int            @default(0)
  winnerUserId            String?
  item                    Item           @relation(fields: [itemId], references: [id])
  attempts                Attempt[]
  winners                 Winner[]
  purchases               ItemPurchase[]
  ledgers                 CreditLedger[]

  @@index([itemId, state])
  @@unique([itemId, sequence])
}

model Attempt {
  id               String     @id @default(cuid())
  createdAt        DateTime   @default(now())
  userId           String
  itemId           String
  roundId          String?
  dayKey           String
  costCredits      Int        @default(0)
  freeUsed         Int        @default(0)
  paidUsed         Int        @default(0)
  isPaid           Boolean    @default(false)
  scoreMs          Int
  flags            String?
  clientSentAt     DateTime?
  serverReceivedAt DateTime   @default(now())
  user             User       @relation(fields: [userId], references: [id])
  item             Item       @relation(fields: [itemId], references: [id])
  round            ItemRound? @relation(fields: [roundId], references: [id])

  @@index([itemId, dayKey])
  @@index([userId, dayKey])
  @@index([itemId, dayKey, userId])
  @@index([roundId, itemId])
}

model Winner {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  itemId        String
  roundId       String?
  dayKey        String
  userId        String
  rank          Int
  scoreMs       Int
  alias         String?
  rewardType    String     @default("ITEM")
  rewardCredits Int        @default(0)
  item          Item       @relation(fields: [itemId], references: [id])
  user          User       @relation(fields: [userId], references: [id])
  round         ItemRound? @relation(fields: [roundId], references: [id])

  @@index([itemId, dayKey])
  @@index([userId, dayKey])
  @@index([roundId, rank])
  @@unique([itemId, dayKey, userId])
}

model ItemPurchase {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  itemId          String
  roundId         String?
  userId          String
  dayKey          String
  priceCredits    Int
  spentCredits    Int
  discountPct     Int
  discountCredits Int
  payCredits      Int
  tierKey         String
  item            Item       @relation(fields: [itemId], references: [id])
  user            User       @relation(fields: [userId], references: [id])
  round           ItemRound? @relation(fields: [roundId], references: [id])

  @@index([itemId, dayKey])
  @@index([userId, dayKey])
  @@index([roundId, userId])
  @@unique([itemId, dayKey, userId])
}

model CreditLedger {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  userId    String
  itemId    String?
  roundId   String?
  kind      String
  credits   Int
  note      String?
  user      User       @relation(fields: [userId], references: [id])
  item      Item?      @relation(fields: [itemId], references: [id])
  round     ItemRound? @relation(fields: [roundId], references: [id])

  @@index([userId, createdAt])
  @@index([roundId, kind])
}

model DailyFreeBucketGrant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  bucketKey String
  dayKey    String
  userId    String?
  credits   Int      @default(0)
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([bucketKey, dayKey])
  @@index([userId, dayKey])
  @@index([dayKey])
}

model LoginCode {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  email      String
  codeHash   String
  bucketKey  String?
  ipHash     String?
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([email, createdAt])
  @@index([bucketKey, createdAt])
  @@index([ipHash, createdAt])
}

model Referral {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  code                  String
  referrerUserId        String
  referredUserId        String?
  referredBucketKey     String
  status                String    @default("PENDING")
  qualifiedAt           DateTime?
  rewardedAt            DateTime?
  referrerRewardCredits Int       @default(20)
  referredRewardCredits Int       @default(10)
  referrer              User      @relation("ReferralReferrer", fields: [referrerUserId], references: [id])
  referred              User?     @relation("ReferralReferred", fields: [referredUserId], references: [id])

  @@unique([referredBucketKey])
  @@index([code])
  @@index([referrerUserId, createdAt])
  @@index([referredUserId, createdAt])
  @@index([status, createdAt])
}

model SurveyResponse {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  surveyKey     String
  userId        String?
  bucketKey     String
  answersJson   Json
  rewardCredits Int      @default(0)
  rewardedAt    DateTime?
  user          User?    @relation(fields: [userId], references: [id])

  @@unique([surveyKey, bucketKey])
  @@index([userId, createdAt])
}
